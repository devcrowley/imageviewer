{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Image Viewer",
    "version": "0.1.0",
    "identifier": "com.imageviewer.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "yarn dev",
        "beforeBuildCommand": "yarn build"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Image Viewer",
                "width": 1280,
                "height": 800,
                "minWidth": 600,
                "minHeight": 400,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
