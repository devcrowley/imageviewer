{
    "identifier": "default",
    "description": "Default permissions for the main Image Viewer window",
    "local": true,
    "windows": ["main"],
    "permissions": [
        "core:default",
        "dialog:default",
        "dialog:allow-open",
        "fs:default",
        "fs:read-files",
        "fs:allow-read-text-file",
        "fs:allow-write-text-file",
        "fs:allow-read-dir",
        "fs:allow-exists",
        "fs:allow-stat"
    ]
}
